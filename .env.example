# Supabase configuration
# Copy this file to .env and fill in your Supabase project credentials.
# Find these in Supabase Dashboard → Settings → API
# Do NOT commit .env to git.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — used for voice search (Whisper speech-to-text).
# Without this key, voice search runs in demo mode with a mock transcript.
EXPO_PUBLIC_OPENAI_API_KEY=

# Optional — base URL for share links (invite + restaurant landing pages).
# Defaults to the GitHub Pages deploy if unset. Override when cravemap.app ships.
EXPO_PUBLIC_WEB_BASE_URL=
